UPLOAD_DIR=./uploads (optionnel, défaut auto)
# ─────────────────────────────────────────────────────────────────────────────
# Eco-Formalités — Variables d'environnement
# Copiez ce fichier en ".env" et remplissez les valeurs.
# Ne commitez JAMAIS le fichier .env dans git.
# ─────────────────────────────────────────────────────────────────────────────

# Serveur
PORT=3001

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Créez un compte sur https://resend.com et ajoutez votre domaine.
# Copiez la clé API ici.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Expéditeur — doit correspondre à un domaine vérifié dans Resend
FROM_EMAIL=no-reply@votre-domaine.fr
FROM_NAME=Eco-Formalités

# ── Sécurité (Phase 2) ────────────────────────────────────────────────────────
# Clé secrète pour les JWT (générez avec: openssl rand -hex 64)
# JWT_SECRET=votre_secret_tres_long_et_aleatoire

# ── Stockage fichiers (Phase 2 — GED) ─────────────────────────────────────────
# Option A : Stockage local (par défaut)
# UPLOAD_DIR=./uploads

# Option B : MinIO (S3-compatible, pour VPS)
# MINIO_ENDPOINT=localhost
# MINIO_PORT=9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=eco-formalites
